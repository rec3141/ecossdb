// ECOSSDB – Ecosystem Services Database Pipeline
// Maps metagenomic functional annotations to ecosystem services

params {
    help            = false

    // --- Input ---
    annotations     = null          // Path to annotation file(s) or directory
    input_format    = 'auto'        // auto | danaseq | kofamscan | eggnog | gff | ko_list | dbcan
    proteins        = null          // Protein FASTA (.faa) for custom HMM search
    contig2bin      = null          // Contig-to-bin mapping TSV (contig_id\tbin_id)
    sample_id       = 'sample'      // Sample identifier

    // --- Output ---
    outdir          = 'results'
    store_dir       = null

    // --- Ontology ---
    es_ontology     = "${projectDir}/db/ontology/cices_v5.2.tsv"
    es_ontology_raw = null          // Raw CICES xlsx or custom hierarchical TSV

    // --- Mapping ---
    es_mapping      = "${projectDir}/db/mappings/es_gene_mapping.tsv"

    // --- Custom HMM (optional) ---
    es_hmm_db       = null          // Path to custom HMM profiles
    es_hmm_meta     = null          // Path to HMM metadata TSV

    // --- Scoring ---
    role_weights    = 'producer:1.0,transformer:0.7,consumer:-0.3,inhibitor:-0.5'

    // --- SDG mapping ---
    sdg             = true
}

// --- Process resource labels ---
process {
    withLabel: process_low {
        cpus   = 2
        memory = '4 GB'
        time   = '3h'
    }
    withLabel: process_medium {
        cpus   = 8
        memory = '16 GB'
        time   = '12h'
    }
}

// --- Conda environments ---
process {
    withLabel: ecossdb_core {
        conda = "${projectDir}/envs/ecossdb-core.yml"
    }
    withLabel: ecossdb_hmm {
        conda = "${projectDir}/envs/ecossdb-hmm.yml"
    }
}

// --- Profiles ---
profiles {
    standard {
        // defaults
    }
    test {
        params.annotations = "${projectDir}/test-data/annotations.tsv"
        params.contig2bin  = "${projectDir}/test-data/contig2bin.tsv"
        params.sample_id   = 'test_sample'
        params.outdir      = 'test-results'
    }
}

// --- Reports ---
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.html"
}
